# Public domains
API_DOMAIN=api.yourdomain.com
APP_URL=https://www.yourdomain.com
CORS_ORIGINS=https://www.yourdomain.com,https://yourdomain.com

# Prefer AUTH_DISABLED=1 for a simple self-host. Set 0 only if Supabase auth is configured.
AUTH_DISABLED=1
BILLING_DISABLED=1

# Optional Supabase (only if AUTH_DISABLED=0)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# LLM key is required to create runs / explore (not optional)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
